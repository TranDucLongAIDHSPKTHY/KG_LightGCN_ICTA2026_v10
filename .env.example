# .env.example — v10 (copy sang .env và chỉnh sửa)
# Nguồn dữ liệu: KGAT repo (xiangwang1223)

# Thư mục raw data (KGAT repo format)
RAW_DIR=/data/phuongtran/project_v10/raw

# Thư mục unified data (sau preprocessing)
DATA_DIR=/data/phuongtran/project_v10/unified

# Thư mục kết quả
RESULTS_ROOT=results

# Device: auto | cpu | cuda | cuda:0
DEVICE=auto

# Số worker cho DataLoader
NUM_WORKERS=0
